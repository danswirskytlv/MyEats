<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="8dp">

    <ImageView
        android:id="@+id/comment_avatar"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:contentDescription="@string/avatar_desc"
        android:padding="7dp"
        android:background="@drawable/bg_logo_circle"
        android:src="@drawable/ic_utensils"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/comment_author"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/comment_avatar"
        app:layout_constraintStart_toEndOf="@id/comment_avatar" />

    <TextView
        android:id="@+id/chef_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:paddingHorizontal="7dp"
        android:paddingVertical="1dp"
        android:text="@string/comment_owner_badge"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:background="@drawable/bg_chef_badge"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/comment_author"
        app:layout_constraintBottom_toBottomOf="@id/comment_author"
        app:layout_constraintStart_toEndOf="@id/comment_author" />

    <TextView
        android:id="@+id/comment_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="@color/text_secondary"
        app:layout_constraintTop_toTopOf="@id/comment_author"
        app:layout_constraintBottom_toBottomOf="@id/comment_author"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/comment_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginTop="2dp"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/comment_author"
        app:layout_constraintStart_toEndOf="@id/comment_avatar"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Actions row: like + count on the left, edit/delete (own comments) on the right -->
    <ImageView
        android:id="@+id/like_button"
        android:layout_width="26dp"
        android:layout_height="26dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="2dp"
        android:padding="4dp"
        android:src="@drawable/ic_heart_outline"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/like_comment_desc"
        app:layout_constraintTop_toBottomOf="@id/comment_text"
        app:layout_constraintStart_toEndOf="@id/comment_avatar" />

    <TextView
        android:id="@+id/like_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="2dp"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        app:layout_constraintTop_toTopOf="@id/like_button"
        app:layout_constraintBottom_toBottomOf="@id/like_button"
        app:layout_constraintStart_toEndOf="@id/like_button" />

    <ImageView
        android:id="@+id/delete_comment_button"
        android:layout_width="26dp"
        android:layout_height="26dp"
        android:padding="4dp"
        android:src="@drawable/ic_delete_small"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/action_delete"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/like_button"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/edit_comment_button"
        android:layout_width="26dp"
        android:layout_height="26dp"
        android:layout_marginEnd="8dp"
        android:padding="4dp"
        android:src="@drawable/ic_edit_small"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/action_edit"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/like_button"
        app:layout_constraintEnd_toStartOf="@id/delete_comment_button" />

</androidx.constraintlayout.widget.ConstraintLayout>
