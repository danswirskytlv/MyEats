<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MyEats" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary_green</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/amber</item>
        <item name="colorTertiary">@color/brick</item>

        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="fontFamily">@font/plus_jakarta_sans</item>

        <item name="android:windowBackground">@color/cream_bg</item>
        <item name="colorSurface">@color/white</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <item name="android:statusBarColor">@color/cream_bg</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Chips measure text with their own TextAppearance, not the theme font.
         Declaring the font here keeps measuring and drawing in sync
         (otherwise chip labels get clipped). -->
    <style name="TextAppearance.MyEats.Chip" parent="TextAppearance.Material3.LabelLarge">
        <item name="fontFamily">@font/plus_jakarta_sans</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
    </style>
</resources>
